# Temporal server
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233

# cve-collector gRPC server
COLLECTOR_GRPC_HOST=localhost
COLLECTOR_GRPC_PORT=50052

# Temporal task queue where CVECollectorWorkflow is registered
COLLECTOR_TASK_QUEUE=cve-collector

# cve-core gRPC server
CVE_CORE_GRPC_HOST=localhost
CVE_CORE_GRPC_PORT=50051

# cve-core REST API
CVE_CORE_HTTP_HOST=localhost
CVE_CORE_HTTP_PORT=8080

# Application
SERVICE_NAME=vulnctl
# LOG_LEVEL — set in cve-project/.env for docker compose; uncomment here for local dev only
# LOG_LEVEL=INFO
ENVIRONMENT=development
# API_KEY — set in cve-project/.env for docker compose; uncomment here for local dev only
# API_KEY=your-key
